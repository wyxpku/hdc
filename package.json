  },
  "keywords": [
    "openharmony",
    "hdc",
    "device-connector",
    "debugging"
  ],
  "author": "Ethan",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
