{
  "name": "hdc-node",
  "version": "0.0.1",
  "description": "Node.js implementation of OpenHarmony HDC (Host Device Connector)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hdc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
